# REQUIRED: Server Configuration
PORT=5000
NODE_ENV=development

# REQUIRED: PostgreSQL Configuration
POSTGRES_USER=pixelvault_user
POSTGRES_PASSWORD=pixelvault_password
POSTGRES_DB=pixelvault
POSTGRES_PORT=5432
DATABASE_URL=postgresql://pixelvault_user:pixelvault_password@localhost:5432/pixelvault

# REQUIRED: JWT Secret (generate a strong random string for production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_secure_jwt_secret_minimum_32_characters

# REQUIRED: MinIO/S3 Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pixelvault
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
# NODE_ENV=production
