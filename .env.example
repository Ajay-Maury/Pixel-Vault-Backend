PORT=5000
NODE_ENV=development

# PostgreSQL Configuration
POSTGRES_USER=pixelvault
POSTGRES_PASSWORD=pixelvault
POSTGRES_DB=pixelvault
POSTGRES_PORT=5432
DATABASE_URL=postgresql://pixelvault:pixelvault@postgres:5432/pixelvault

# JWT Secret (change this in production!)
JWT_SECRET=your_jwt_secret_change_me_in_production

# MinIO Configuration
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pixelvault
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false

# For Railway Production
# DATABASE_URL=postgresql://user:password@your-railway-postgres:5432/dbname
# MINIO_ENDPOINT=your-s3-provider.com
# MINIO_ACCESS_KEY=your-access-key
# MINIO_SECRET_KEY=your-secret-key
# MINIO_USE_SSL=true
# NODE_ENV=production
